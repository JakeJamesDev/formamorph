# Copy this file to .env.local and fill in your own values for local testing.
# .env.local is gitignored, so your personal config never gets committed.
# All values are optional — if unset, the app falls back to its built-in defaults.

# Backend API (worlds / auth). Overrides .env for your machine only.
# VITE_API_URL_DEV=http://localhost:8797/api

# AI / LLM defaults that seed the in-app Settings screen.
# Endpoint must be the FULL chat-completions URL (the app appends no path).
# VITE_DEFAULT_ENDPOINT=http://127.0.0.1:1234/v1/chat/completions
# VITE_DEFAULT_API_TOKEN=your-api-token-here
# VITE_DEFAULT_MODEL_NAME=your-model-name
# VITE_DEFAULT_CONTEXT_WINDOW=10750
# VITE_DEFAULT_MAX_TOKENS=1024
